{
  "title": "API Metrics",
  "uid": "api-metrics",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["zatoshi", "api"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "id": 1,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 100 }] },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (service)",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P50 Latency",
      "type": "timeseries",
      "id": 2,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 0.5 }, { "color": "red", "value": 1 }] },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P95 Latency",
      "type": "timeseries",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 1 }, { "color": "red", "value": 2 }] },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "P99 Latency",
      "type": "timeseries",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 3 }, { "color": "red", "value": 5 }] },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "id": 5,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 3 }, { "color": "red", "value": 5 }] },
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total[5m])) by (service) * 100",
          "legendFormat": "{{ service }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Users",
      "type": "gauge",
      "id": 6,
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 1000 }, { "color": "red", "value": 5000 }] },
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "active_users",
          "legendFormat": "Active Users",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "id": 7,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "red", "value": 0 }] }
        }
      },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{service=\"api\"}",
          "legendFormat": "API Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "title": "HTTP Status Code Breakdown",
      "type": "timeseries",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"2..\"}[5m])) by (service)",
          "legendFormat": "{{ service }} 2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[5m])) by (service)",
          "legendFormat": "{{ service }} 4xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (service)",
          "legendFormat": "{{ service }} 5xx",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Request Rate by Route (Top 10)",
      "type": "table",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total[5m])) by (route))",
          "legendFormat": "{{ route }}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "indexByName": { "route": 0, "Value": 1 } }
        }
      ]
    }
  ]
}
